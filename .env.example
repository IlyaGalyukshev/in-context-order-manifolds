# Copy to .env and fill in. NEVER commit .env (git-ignored).
# Used only by generator/llm_assist.py — offline authoring of template pools.
# The per-stimulus generator path is deterministic and never calls an API.

OPENROUTER_API_KEY=
OPENROUTER_BASE_URL=https://openrouter.ai/api/v1
# Optional HTTP(S) proxy if OpenRouter is unreachable from your network:
OPENROUTER_PROXY=
